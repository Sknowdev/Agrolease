# AgroLease - environment variable template
# Copy this file to .env (repo root, gitignored) for the scraper,
# and set the equivalent NEXT_PUBLIC_ / server-only values in web/.env.local
# and in the Vercel project settings for staging/production.

# ---------------------------------------------------------------------------
# SUPABASE - staging project (used by default in local development)
# Get these from: Supabase dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
# Public/anon key is safe to expose to the browser - used by the Next.js app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key

# ---------------------------------------------------------------------------
# SUPABASE - production project
# Only used when NODE_ENV=production / when deployed on Vercel production
# ---------------------------------------------------------------------------
SUPABASE_URL_PRODUCTION=https://YOUR-PRODUCTION-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY_PRODUCTION=your-production-service-role-key
NEXT_PUBLIC_SUPABASE_URL_PRODUCTION=https://YOUR-PRODUCTION-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_PRODUCTION=your-production-anon-key

# ---------------------------------------------------------------------------
# SCRAPER SOURCES - live now, no API key required
# ---------------------------------------------------------------------------
# Nigeria (FMARD) - public site, no key needed
# Ghana (GCX) - public site, no key needed
# South Africa (DAFF / nda.gov.za) - public site, no key needed
# Brazil (CONAB) - public site, no key needed
# United Kingdom (DEFRA / gov.uk) - public open data, no key needed

# ---------------------------------------------------------------------------
# SCRAPER SOURCES - next wave, require an API key you provide later
# Uncomment and fill in when ready to activate each country.
# ---------------------------------------------------------------------------
# Kenya - KilimoSTAT API
# KILIMOSTAT_API_KEY=

# India - data.gov.in / Agmarknet API
# DATA_GOV_IN_API_KEY=

# Indonesia - BPS Statistics API
# BPS_API_KEY=

# United States - USDA NASS QuickStats API
# USDA_NASS_API_KEY=

# ---------------------------------------------------------------------------
# SITE
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://agrolease.xyz
