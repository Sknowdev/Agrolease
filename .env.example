# AgroLease - environment variable template
# Copy this file to .env (repo root, gitignored) for the scraper,
# and set the equivalent NEXT_PUBLIC_ / server-only values in web/.env.local
# and in the Vercel project settings for staging/production.

# ---------------------------------------------------------------------------
# SUPABASE - staging project (used by default in local development)
# Get these from: Supabase dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
# Public/anon key is safe to expose to the browser - used by the Next.js app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key

# ---------------------------------------------------------------------------
# SUPABASE - production project
# Used when SCRAPER_ENV=production (scraper) / the Vercel Production
# environment (web app)
# ---------------------------------------------------------------------------
SUPABASE_URL_PRODUCTION=https://YOUR-PRODUCTION-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY_PRODUCTION=your-production-service-role-key
NEXT_PUBLIC_SUPABASE_URL_PRODUCTION=https://YOUR-PRODUCTION-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_PRODUCTION=your-production-anon-key

# ---------------------------------------------------------------------------
# SCRAPER SOURCES - live now, no API key required
#
# IMPORTANT: this list reflects what was actually verified working, not
# the original plan. Several originally-planned sources turned out to be
# dead or unusable when checked live - see web_progress.md for the full
# story on each one. None of the sources below need any key/env var of
# their own; they're listed here only so it's clear what `--source=all`
# actually depends on.
# ---------------------------------------------------------------------------
# Nigeria - NBS Food Price Tracking (nigeriafoodpricetracking.ng CSV export)
#   Originally planned as FMARD - that source is dead (fmard.gov.ng now
#   redirects to a site with no price data at all).
# United Kingdom - DEFRA / gov.uk Agricultural Price Indices (still works
#   as originally planned).
# Kenya, Ethiopia, Tanzania, Uganda, Rwanda, Cameroon, Ivory Coast,
# Senegal, Mozambique, Egypt, Mali, Burkina Faso - WFP Global Food Prices
#   (republished on HDX: data.humdata.org/dataset/global-wfp-food-prices).
#   Originally planned as "KilimoSTAT" (Kenya) / "WFP VAM" (everyone
#   else) - neither of those was ever actually working; this HDX-hosted
#   CSV is the real, verified, no-key replacement.
# Kenya, Nigeria, Ethiopia, Uganda, Cameroon, Senegal, Mozambique, Mali,
# Burkina Faso - World Bank Real Time Food Prices, "estimated" series
#   (republished on HDX: data.humdata.org/dataset/global-real-time-food-prices),
#   run via the *-rtfp source keys (e.g. --source=kenya-rtfp).
#
# Ghana (GCX) and South Africa (DAFF) - NOT scrapable. GCX is now a
#   members-only trading platform; DAFF only publishes PDF reports. Both
#   are admin-entered-price fallbacks, not automated.
# Brazil (CONAB) - NOT scrapable (JS-only consulta tool, no public feed
#   or API found). Admin-entered-price fallback.
# Zambia, Zimbabwe - still "coming soon". No verified working source
#   found yet for either (Zambia's WFP data has no usable crop rows yet;
#   Zimbabwe isn't in the WFP or RTFP country lists at all).

# ---------------------------------------------------------------------------
# RAINFALL - Open-Meteo Forecast API
# Real, verified, no API key required, works globally. Run via:
#   node src/index.js --rainfall
# This is diagnostic-only for now (prints to stdout) - there is no
# rainfall_observations table yet, so nothing is written to Supabase.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# SCRAPER SOURCES - not yet built, would require an API key you provide
# later. Kept here as placeholders for a genuinely future wave - unlike
# the "next wave" section in earlier versions of this file, none of the
# countries below currently have a working scraper module wired up.
# Uncomment and fill in only once a real integration is actually built.
# ---------------------------------------------------------------------------
# India - data.gov.in / Agmarknet API
# DATA_GOV_IN_API_KEY=

# Indonesia - BPS Statistics API
# BPS_API_KEY=

# United States - USDA NASS QuickStats API
# USDA_NASS_API_KEY=

# ---------------------------------------------------------------------------
# SITE
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://agrolease.xyz
