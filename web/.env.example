# AgroLease web app - environment variable template
# Copy this file to web/.env.local (gitignored) for local development.
# For deployed environments, set the same keys in the Vercel project's
# Environment Variables settings (separately for the Preview/staging
# environment and the Production environment).
#
# These are the browser-exposed (NEXT_PUBLIC_) Supabase anon-key
# credentials only. The web app never uses the service_role key - that
# is scraper-only (see the root .env.example, which also documents which
# scraper data sources are actually verified working vs. still
# "coming soon" - Ghana/South Africa/Brazil/Zambia/Zimbabwe have no
# working automated source yet).

# ---------------------------------------------------------------------------
# SUPABASE - use the STAGING project locally, the PRODUCTION project when
# this is deployed as the Vercel Production environment.
# Get these from: Supabase dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# SITE
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
